<%- include('../partials/header') %>

<% if (locals.isDemo) { %>
  <div style="text-align: center; margin: 20px auto;">
    <h2 style="margin: 0; color: #ff00ff; text-transform: uppercase; letter-spacing: 2px; font-weight: bold; text-shadow: 0 0 5px #ff00ff; font-size: 1.2rem;">Demo Mode</h2>
  </div>

  <script>
    document.addEventListener('click', (e) => {
      const target = e.target.closest('button, a, input[type="submit"]');
      const headerLink = e.target.closest('.main-header a');
      const logoutBtn = e.target.closest('[href="/logout"]');

      if (headerLink || logoutBtn) {
        return;
      }
      if (target) {
        e.preventDefault();
        e.stopPropagation();
        alert('demo mode contact for full expirence');
        return false;
      }
    }, true);
  </script>
<% } %>

<div class="form-container">
  <h2>Edit Art Piece</h2>
  
  <div style="text-align: center; margin-bottom: 20px;">
    <img src="<%= art.imageUrl %>" alt="<%= art.title %>" style="max-width: 200px; border-radius: 8px;">
  </div>

  <form action="/admin/edit/<%= art._id %>" method="POST">
    <div class="form-group">
      <label for="title">Art Title</label>
      <input type="text" id="title" name="title" value="<%= art.title %>" required>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description"><%= art.description %></textarea>
    </div>

    <button type="submit" class="btn">Update Art Piece</button>
    <a href="/admin" style="display: block; text-align: center; margin-top: 15px; color: #666; text-decoration: none;">Cancel</a>
  </form>
</div>

<%- include('../partials/footer') %>
