<%- include('partials/header') %>

<header style="text-align: center; margin-bottom: 40px;">
  <h1 style="font-size: 2.5rem; margin-bottom: 10px;">Vibe Showcase</h1>
</header>

<div class="top-9-grid">
  <% if (typeof featuredArt !== 'undefined' && featuredArt.length > 0) { %>
    <% featuredArt.forEach(art => { %>
      <div class="art-card">
        <img src="<%= art.imageUrl %>" alt="<%= art.title %>" loading="lazy">
        <div class="art-card-info">
          <h3><%= art.title %></h3>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div style="grid-column: 1 / -1; text-align: center; margin-top: 50px; padding: 60px; border: 2px dashed #ff00ff; border-radius: 12px; background: #fff;">
      <h2 style="color: #ff00ff; letter-spacing: 4px; text-transform: uppercase; margin-bottom: 10px;">Vibe Under Curation</h2>
      <p style="color: #666;">Our curated showcase is being updated. Explore the full collection below!</p>
    </div>
  <% } %>
</div>

<div style="text-align: center; margin-top: 50px;">
  <a href="/collection" class="btn-neon">Explore Whole Collection</a>
</div>

<%- include('partials/footer') %>
